# AR Web App - Configuration

## Server Configuration
NODE_ENV=development
PORT=8080

## Model Configuration
DEFAULT_MODEL_PATH=./public/models/
MODEL_FILE_SIZE_LIMIT=50000000

## Audio Configuration
AUDIO_PATH=./public/audio/
DEFAULT_AUDIO_VOLUME=0.7

## QR Code Configuration
QR_CODE_PATH=./public/qr/
QR_CODE_SIZE=300
QR_ERROR_CORRECTION=H

## Features
ENABLE_CAMERA=true
ENABLE_AUDIO=true
ENABLE_ANIMATIONS=true
ENABLE_AUTOROTATE=false

## Logging
LOG_LEVEL=info
DEBUG_MODE=false
